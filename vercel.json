{
  "functions": {
    "api/chat.js":    { "runtime": "nodejs20.x" },
    "api/contact.js": { "runtime": "nodejs20.x" }
  },
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/services/brand",     "destination": "/services/brand.html" },
    { "source": "/services/digital",  "destination": "/services/digital.html" },
    { "source": "/services/ai",       "destination": "/services/ai.html" },
    { "source": "/services/software", "destination": "/services/software.html" },
    { "source": "/intelligence",      "destination": "/intelligence.html" },
    { "source": "/about",             "destination": "/about.html" },
    { "source": "/contact",           "destination": "/contact.html" },
    { "source": "/pricing",           "destination": "/pricing.html" }
  ],
  "redirects": [
    { "source": "/services",          "destination": "/services/ai", "permanent": false },
    { "source": "/blog",              "destination": "https://n3xus.media/blog", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection",          "value": "1; mode=block" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type",  "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type",  "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/.well-known/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type",  "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
